# Configuração do servidor MCP Office 365 — PoC Fase 0
# Copiar para .env e preencher. O .env NUNCA é commitado (ver .gitignore).

# --- Entra ID (Plano B: client confidencial) ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Authority Entra; normalmente https://login.microsoftonline.com/<tenant_id>
ENTRA_AUTHORITY=

# Redirect URI registado no Entra para o callback do Plano B (domínio final)
OAUTH_REDIRECT_URI=https://mw-mcp-office365.mobiweb.pt/callback

# Scopes delegados (separados por espaço) — Fase 1 acrescenta os de Email
GRAPH_SCOPES=User.Read Mail.Read Mail.Send Mail.ReadWrite offline_access openid profile

# --- Plano A (MCP como OAuth resource/authorization server para o Claude) ---
# Issuer público e base URL do servidor (domínio final, com TLS)
MCP_ISSUER_URL=https://mw-mcp-office365.mobiweb.pt
MCP_PUBLIC_BASE_URL=https://mw-mcp-office365.mobiweb.pt

# --- Token store / cifra ---
# Caminho do SQLite (fora da raiz web, permissões restritas)
TOKEN_STORE_PATH=./tokens.db
# Chave AES-256 em base64 (32 bytes). Gerar com:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=

# --- Aprovação em duas fases (prepare->confirm) ---
# TTL (segundos) do token de confirmação de operações de escrita.
APPROVAL_TTL_SECONDS=300

# --- Fase Aprendizagem (US-L.x) — opt-in, DESLIGADA por defeito (RGPD) ---
# Mesmo com LEARNING_ENABLED=true, cada utilizador tem de fazer opt-in (learning_opt_in).
LEARNING_ENABLED=false
LEARNING_MIN_CONFIDENCE=0.5
LEARNING_TOP_N=3
LEARNING_RETENTION_DAYS=180

# --- Runtime ---
LOG_LEVEL=INFO
BIND_HOST=127.0.0.1
BIND_PORT=8000
